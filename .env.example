# FRAUDX — Configuration
# Copier ce fichier en .env et ajuster les valeurs

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# === Dashboard ===
DASHBOARD_PORT=8501

# === Database ===
DB_PATH=data/fraudx.db

# === Models ===
MODELS_PATH=models/
MODEL_NAME=xgb_model.pkl
THRESHOLD_PATH=models/best_threshold.npy

# === Training ===
TRAIN_DATASET=ieee
TRAIN_FAST=false
TRAIN_OPTUNA_TRIALS=30
TRAIN_SEED=42

# === Retraining ===
RETRAIN_MIN_SAMPLES=500
RETRAIN_SCHEDULE_HOURS=24

# === Logging ===
LOG_LEVEL=INFO
